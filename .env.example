# 数据库
DATABASE_URL="file:./prisma/dev.db"

# JWT 密钥
JWT_SECRET="your-jwt-secret-key"
ADMIN_JWT_SECRET="your-admin-jwt-secret-key"

# 腾讯云 COS 配置
COS_SECRET_ID="your-cos-secret-id"
COS_SECRET_KEY="your-cos-secret-key"
COS_BUCKET="your-bucket-name-1234567890"
COS_REGION="ap-chongqing"
COS_CDN_DOMAIN=""

# 游戏卡图 CDN（可选，强烈推荐配置以加速 /game 页图片加载）
# 使用 node scripts/upload-cards.js 把 public/cards/* 上传到 COS 后配置本项
# 配置后前端会自动把 /cards/xxx 替换为 {CDN}/cards/xxx?imageMogr2/format/webp/quality/85/thumbnail/800x
# 首屏体积 60MB → ~3MB，提升 15-20 倍
# 值示例：
#   - 用 COS 原始域名：https://your-bucket-name.cos.ap-chongqing.myqcloud.com
#   - 用 CDN 加速域名：https://cdn.your-domain.com
# NEXT_PUBLIC_CARDS_CDN=""

# 内容安全审核（腾讯云天御，复用 COS 密钥，需在控制台开通）
CONTENT_MODERATION_ENABLED="false"

# 邮件 SMTP（QQ 邮箱）
SMTP_USER="your-qq-email@qq.com"
SMTP_PASS="your-qq-smtp-authorization-code"

# 定时任务密钥（用于 /api/cron/* 接口鉴权，空值时接口无鉴权）
CRON_SECRET="your-strong-random-secret"

# 微博定时同步 Worker（PM2 chenze-weibo-cron 进程读取）
# WEIBO_CRON_URL="http://127.0.0.1:3000/api/cron/weibo-sync"
# WEIBO_CRON_INTERVAL="180000"         # 轮询间隔（毫秒），默认 3 分钟
# WEIBO_CRON_INITIAL_DELAY="30000"     # 首次启动延迟（毫秒），默认 30 秒

# 微博抓取 Cookie（可选，用于绕过风控 HTTP 432）
# 获取方式：浏览器访问 https://m.weibo.cn 登录后，F12 → Network → 任一请求 → 复制 Cookie 请求头整行
# 未配置时会自动尝试获取匿名 cookie，但 IP 触发风控时建议配置真实 cookie
# WEIBO_COOKIE="SUB=_2A25xxx; SUBP=xxx; _T_WM=xxx; WEIBOCN_FROM=xxx"
