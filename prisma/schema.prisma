// Prisma Schema — 1103社区 (ChenZe Community)
// SQLite for dev, can migrate to MySQL/PostgreSQL for production

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户系统 ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("fan") // fan | star(董事长) | assistant(传媒成员)
  level     Int      @default(1)
  badge     String?
  points    Int      @default(0)
  bio       String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  feedbacks     Feedback[]
  pointLogs     PointLog[]
  notifications Notification[]
  reports       Report[]
  bookmarks     Bookmark[]
  postLikes     PostLike[]
  fanWorks      FanWork[]

  @@index([role])
  @@index([isActive])
}

// ==================== 管理员系统 (独立于前台用户) ====================

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("admin") // super_admin | admin | editor
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// ==================== 社区内容 ====================

model Post {
  id        String   @id @default(cuid())
  content   String
  images    String   @default("[]") // JSON array of COS URLs
  isPinned  Boolean  @default(false)
  likes     Int      @default(0)
  hotScore  Float    @default(0) // 热门排序分数，定期刷新
  status    String   @default("published") // draft | published | hidden
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id])
  comments  Comment[]
  postTags  PostTag[]
  bookmarks Bookmark[]
  postLikes PostLike[]

  @@index([authorId])
  @@index([status])
  @@index([isPinned])
  @@index([createdAt])
  @@index([status, hotScore])
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  likes       Int      @default(0)
  postId      String
  authorId    String
  parentId    String?  // 父评论ID，null表示顶级评论
  replyToName String?  // 被回复人的名称（冗余存储，避免关联查询）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  postTags PostTag[]
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// ==================== 相册系统 ====================

model Album {
  id        String   @id @default(cuid())
  title     String
  category  String
  cover     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos Photo[]

  @@index([category])
}

model Photo {
  id          String   @id @default(cuid())
  url         String
  thumbnail   String?
  description String?
  albumId     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}

// ==================== 活动系统 ====================

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String
  cover        String
  startTime    DateTime
  endTime      DateTime
  location     String
  status       String   @default("upcoming") // upcoming | ongoing | ended
  participants Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([startTime])
}

// ==================== 游戏推荐 ====================

model Game {
  id            String   @id @default(cuid())
  name          String
  cover         String
  platform      String
  genre         String
  status        String   @default("playing") // playing | recent | favorite
  lastPlayed    String
  hours         Int      @default(0)
  rating        Int      @default(5)
  comment       String
  description   String
  downloadLinks String   @default("[]") // JSON array [{label, url}]
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// ==================== 时间线 ====================

model TimelineEvent {
  id          String   @id @default(cuid())
  date        String
  title       String
  description String
  type        String // debut | award | release | milestone | event
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

// ==================== 首页轮播 ====================

model HeroSlide {
  id        String   @id @default(cuid())
  image     String
  alt       String
  link      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 站点配置 (KV存储, 可扩展) ====================

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String // JSON string
  label     String? // 人类可读标签
  group     String   @default("general") // general | profile | social | stats
  updatedAt DateTime @updatedAt

  @@index([group])
}

// ==================== 媒体库 (COS文件管理) ====================

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  cosKey    String
  size      Int
  mimeType  String
  width     Int?
  height    Int?
  category  String   @default("general") // avatar | post | album | cover | game | event
  createdAt DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}

// ==================== 公告弹窗 ====================

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  type      String    @default("info")    // info | warning | event | update
  image     String?                        // 可选图片 URL
  link      String?                        // 可选跳转链接
  linkText  String?                        // 链接按钮文字
  isActive  Boolean   @default(true)
  startAt   DateTime? // 定时开始（null = 立即生效）
  endAt     DateTime? // 定时结束（null = 永不过期）
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([startAt])
  @@index([endAt])
}

// ==================== 答题验证 ====================

model QuizQuestion {
  id        String   @id @default(cuid())
  question  String
  options   String   // JSON array of strings, e.g. ["A","B","C","D"]
  answer    Int      // 正确选项索引 (0-based)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ==================== 注册安全闭环 ====================

model VerificationCode {
  id         String   @id @default(cuid())
  email      String
  scene      String   // register | reset
  codeHash   String
  ip         String?
  uaHash     String?
  status     String   @default("pending") // pending | consumed | expired | revoked
  sendCount  Int      @default(1)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email, scene, createdAt])
  @@index([status, expiresAt])
}

model QuizPassToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  email       String?
  ip          String?
  uaHash      String?
  questionSet String?  // JSON array of quiz ids
  score       Int      @default(0)
  status      String   @default("active") // active | consumed | expired | revoked
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([email, createdAt])
}

model SecurityEvent {
  id         String   @id @default(cuid())
  eventType  String
  userId     String?
  email      String?
  ip         String?
  uaHash     String?
  targetType String?
  targetId   String?
  result     String   @default("success") // success | reject | error
  reason     String?
  meta       String?  // JSON string
  createdAt  DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// ==================== 音乐播放器 ====================

model MusicTrack {
  id        String   @id @default(cuid())
  title     String
  artist    String   @default("陈泽")
  src       String   // COS 音频 URL
  cover     String?  // 封面图 URL
  duration  Int?     // 时长(秒)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

// ==================== 积分记录 ====================

model PointLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // daily_login | post | comment | be_liked | event
  points    Int      // 正数=获得 负数=扣除
  detail    String?  // 可选描述，如 "发布帖子xxx"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, action, createdAt])
}

// ==================== 通知系统 ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // comment | like | pin | system
  title     String
  content   String
  link      String?  // 跳转链接，如 /community/xxx
  isRead    Boolean  @default(false)
  fromId    String?  // 触发者ID（可选，系统通知无触发者）
  fromName  String?  // 触发者名称（冗余存储，避免关联查询）
  fromAvatar String? // 触发者头像
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ==================== 反馈建议 ====================

model Feedback {
  id        String   @id @default(cuid())
  type      String   @default("suggestion") // suggestion | bug | other
  content   String
  contact   String?  // 可选联系方式(邮箱/微信等)
  status    String   @default("pending") // pending | read | resolved
  reply     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ==================== 收藏系统 ====================

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

// ==================== 点赞记录（去重防刷） ====================

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

// ==================== 违禁词管理 ====================

model BannedWord {
  id        String   @id @default(cuid())
  word      String   @unique
  category  String   @default("custom") // politics | porn | gambling | violence | ad | abuse | custom
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

// ==================== 梗百科 ====================

model Meme {
  id          String   @id @default(cuid())
  title       String
  origin      String   // 梗的出处/起源描述
  description String   // 详细解释
  example     String?  // 用法示例
  image       String?  // 配图 URL
  video       String?  // 视频 URL
  tags        String   @default("[]") // JSON array of tag strings, e.g. ["直播","名场面"]
  popularity  Int      @default(0) // 热度/引用次数
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([popularity])
  @@index([sortOrder])
}

// ==================== 二创作品 ====================

model FanWork {
  id           String   @id @default(cuid())
  title        String
  description  String?
  type         String   @default("image") // image | video
  cover        String   // 封面图 URL
  contentUrl   String?  // 视频链接
  images       String   @default("[]") // JSON array of image/video URLs
  authorName   String   // 作者名（展示用）
  authorAvatar String?  // 作者头像
  userId       String?  // 上传用户ID（注册用户投稿时关联）
  source       String?  // 来源平台（B站/微博/抖音等）
  sourceUrl    String?  // 来源链接
  likes        Int      @default(0)
  status       String   @default("pending") // pending | approved | rejected
  rejectReason String?  // 驳回原因
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false) // 精选推荐
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([userId])
}

// ==================== 举报系统 ====================

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  targetType  String   // post | comment | user
  targetId    String
  reason      String   // spam | abuse | inappropriate | other
  description String?  // 补充描述
  status      String   @default("pending") // pending | reviewed | resolved | dismissed
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([createdAt])
}

// ============================================================
// ==================== TCG 卡牌对战系统 ====================
// 独立于社区系统，管理后台路由 /tcg-admin/* · API /api/tcg/*
// 表名统一 Tcg 前缀，与社区表完全隔离，可独立回滚 / 独立部署
// ============================================================

// -------------------- TCG · 卡牌数据 --------------------

model TcgCard {
  id          String   @id                    // 固定编号如 C01 / I08 / E12
  name        String
  type        String                           // character | item | equipment | effect | event
  subtype     String?                          // instant | weapon | armor
  rarity      String                           // N | R | SR | SSR
  cost        Int      @default(0)
  attack      Int?
  health      Int?
  description String                           // 含【关键字】的规则描述
  flavor      String?
  imagePath   String?                          // 本地路径 /cards/*.png 或 COS URL
  effectHooks String   @default("[]")          // JSON array: CardEffectHook[]（trigger/effectId/params）见 src/lib/tcg/effectHooks.ts
  keywords    String   @default("[]")          // JSON array: taunt / charge / stealth ...
  synergies   String   @default("[]")          // JSON array: 卡牌联动配置（CardSynergy[]）见 src/lib/tcg/synergy.ts
  seasonId    String?                          // 限定赛季 null = 通用池
  status      String   @default("active")      // active | disabled | draft
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([rarity])
  @@index([status])
  @@index([seasonId])
}

model TcgDeckPreset {
  id          String   @id @default(cuid())
  name        String                           // 「铁粉嘲讽」「连击流量」...
  description String
  archetype   String                           // aggro | control | combo
  cardIds     String                           // JSON: [{id, count}]
  isStarter   Boolean  @default(false)         // 新手起步卡组
  status      String   @default("active")      // active | disabled
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isStarter])
  @@index([status])
}

// -------------------- TCG · 玩家资产 --------------------

model TcgPlayer {
  userId      String   @id                     // 与 User.id 一致
  rating      Int      @default(1000)          // ELO 分
  tier        String   @default("iron")        // iron | silver | gold | diamond | master
  energy      Int      @default(5)             // 当日剩余对战能量
  energyDate  String   @default("")            // YYYY-MM-DD 重置日期
  wins        Int      @default(0)
  losses      Int      @default(0)
  banStatus   String   @default("normal")      // normal | warned | banned
  banUntil    DateTime?
  banReason   String?
  lastPlayAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tier])
  @@index([banStatus])
  @@index([lastPlayAt])
}

model TcgCollection {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  count     Int      @default(1)                // 持有数量
  shards    Int      @default(0)                // 碎片（10 碎 = 1 张）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
}

model TcgDeck {
  id        String   @id @default(cuid())
  userId    String
  name      String
  cardIds   String                               // JSON: [{id, count}]
  isActive  Boolean  @default(false)             // 当前出战卡组
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}

// -------------------- TCG · 对局 --------------------

model TcgMatch {
  id          String   @id @default(cuid())
  mode        String                              // practice | ranked | friend | boss
  seasonId    String?
  playerAId   String                              // User.id
  playerBId   String?                             // null = AI / Boss
  deckA       String                              // JSON 快照
  deckB       String                              // JSON 快照
  replay      String                              // JSON action 序列（engine 可重放）
  winnerId    String?
  ratingDelta Int      @default(0)                // A 的 ELO 变化量
  turns       Int      @default(0)
  durationSec Int      @default(0)
  endedReason String?                             // hp_zero | turn_15 | surrender | timeout
  createdAt   DateTime @default(now())

  @@index([playerAId, createdAt])
  @@index([playerBId, createdAt])
  @@index([seasonId])
  @@index([mode])
  @@index([createdAt])
}

model TcgSeason {
  id            String   @id @default(cuid())
  name          String                             // 「S1 · 流量纪元」
  startAt       DateTime
  endAt         DateTime
  status        String   @default("draft")         // draft | ongoing | settling | closed
  rewardRules   String   @default("{}")            // JSON：段位 → 奖励配置
  featuredCards String   @default("[]")            // JSON: 本季限定卡 id 列表
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// -------------------- TCG · 运营 --------------------

model TcgOperator {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("tcg_editor")       // tcg_super | tcg_ops | tcg_editor
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model TcgAuditLog {
  id         String   @id @default(cuid())
  operatorId String
  action     String                                // card.update / player.ban / season.settle ...
  targetType String?                               // card | player | match | season ...
  targetId   String?
  before     String?                               // JSON diff 前
  after      String?                               // JSON diff 后
  note       String?                               // 操作备注（补偿理由等）
  ip         String?
  createdAt  DateTime @default(now())

  @@index([operatorId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// -------------------- TCG · 好友房对战 --------------------

model TcgRoom {
  id        String   @id @default(cuid())
  code      String   @unique                 // 6 位邀请码
  hostId    String                            // 创建者用户 ID
  guestId   String?                           // 加入者用户 ID
  hostDeck  String   @default("[]")          // JSON: 房主卡组
  guestDeck String   @default("[]")          // JSON: 挑战者卡组
  state     String   @default("{}")          // JSON: 对战 GameState
  version   Int      @default(0)             // 客户端轮询版本号
  status    String   @default("waiting")     // waiting | ready | playing | finished
  winnerId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([hostId])
  @@index([status])
  @@index([createdAt])
}
